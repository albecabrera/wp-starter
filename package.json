{
  "name": "wp-starter",
  "version": "1.0.0",
  "description": "Lightweight WordPress starter theme",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/main.css -o ./assets/css/output.css --watch",
    "build": "tailwindcss -i ./assets/css/main.css -o ./assets/css/output.css --minify",
    "test": "playwright test",
    "test:responsive": "playwright test tests/responsive/",
    "test:forms": "playwright test tests/forms/",
    "test:a11y": "playwright test tests/accessibility/",
    "test:screenshots": "playwright test tests/screenshots/",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "tailwindcss": "^3.4.0"
  }
}
